<?xml version="1.0" encoding="UTF-8"?>
<?include "cpack_variables.wxi"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <?ifdef CPACK_WIX_PRODUCT_ICON?>
    <Icon Id="AwaShortcutIcon.ico" SourceFile="$(var.CPACK_WIX_PRODUCT_ICON)"/>
    <?endif?>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Directory Id="DesktopFolder" Name="Desktop"/>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AwaProgramMenuFolder" Name="AwaKurageDownloader"/>
      </Directory>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="DesktopFolder">
      <Component Id="AwaDesktopShortcutComponent" Guid="2A358CE8-2343-4C68-B37B-E95B2481D838">
        <Shortcut Id="AwaDesktopShortcut"
                  Name="AwaKurageDownloader"
                  Description="@AWA_WIX_SHORTCUT_DESCRIPTION@"
                  Target="[CM_DP_bin]AwaKurageDownloader.exe"
                  Icon="AwaShortcutIcon.ico"
                  IconIndex="0"
                  WorkingDirectory="CM_DP_bin"/>
        <RegistryValue Root="HKCU"
                       Key="Software\AwaKurageDownloader"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="AwaProgramMenuFolder">
      <Component Id="AwaStartMenuShortcutComponent" Guid="8F3407DA-1193-4793-A9AF-D0402D328187">
        <Shortcut Id="AwaStartMenuShortcut"
                  Name="@AWA_WIX_START_MENU_SHORTCUT_NAME@"
                  Description="@AWA_WIX_START_MENU_SHORTCUT_DESCRIPTION@"
                  Target="[CM_DP_bin]AwaKurageDownloader.exe"
                  Icon="AwaShortcutIcon.ico"
                  IconIndex="0"
                  WorkingDirectory="CM_DP_bin"/>
        <RemoveFolder Id="AwaStartMenuFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\AwaKurageDownloader"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
